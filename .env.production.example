APP_NAME="raulsebastian.es"
APP_ENV=production
APP_KEY=base64:GENERA_CON_php_artisan_key:generate
APP_DEBUG=false
APP_URL=https://raulsebastian.es

APP_LOCALE=es
APP_FALLBACK_LOCALE=es

NGINX_PORT=8180

CACHE_STORE=file
SESSION_DRIVER=file

LOG_CHANNEL=stack
LOG_LEVEL=error

LARAVEL_PDF_DRIVER=dompdf

# TRUST_PROXIES: Set to the specific IP of your reverse proxy (Nginx, Cloudflare, etc.)
# Use * only if behind a fully trusted private network proxy.
# Examples:
#   TRUST_PROXIES=192.168.1.1          # Single proxy IP
#   TRUST_PROXIES=103.21.244.0/22      # Cloudflare IP range (example)
#   TRUST_PROXIES=*                    # All proxies (only if no public exposure before proxy)
TRUST_PROXIES=*
TZ=Europe/Madrid
